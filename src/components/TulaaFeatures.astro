---
// src/components/TulaaFeatures.astro
---

<section id="tulaa" class="section">
    <div class="tulaa-content">
        <h2>The Tulaa App</h2>

        <p class="tulaa-intro">
            Your private, offline-first wellness ecosystem. Access therapeutic
            yoga plans for over 30 conditions, track your cycle, and find deep
            rest—completely free.
        </p>

        <div class="features-minimal-grid">
            <div class="feature-item">
                <h3>Cycle Tracker</h3>
                <p>Predict periods & symptoms</p>
            </div>
            <div class="feature-item">
                <h3>Rhythm</h3>
                <p>Build healthy habit streaks</p>
            </div>
            <div class="feature-item">
                <h3>Hydration</h3>
                <p>Monitor daily water intake</p>
            </div>
            <div class="feature-item">
                <h3>Fasting</h3>
                <p>Track fasting time windows</p>
            </div>
            <div class="feature-item">
                <h3>Health Tips</h3>
                <p>Get research-backed advice</p>
            </div>
            <div class="feature-item">
                <h3>Therapy Blog</h3>
                <p>Learn expert care routines</p>
            </div>
        </div>

        <div class="store-buttons">
            <a
                href="https://play.google.com/store/apps/details?id=life.tulaa"
                target="_blank"
                rel="noopener noreferrer"
                class="store-btn"
            >
                <img
                    src="/images/playstore.svg"
                    alt="Play Store"
                    width="20"
                    height="20"
                />
                Google Play
            </a>
            <a
                href="https://apps.apple.com/in/app/tulaa/id6748626498"
                target="_blank"
                rel="noopener noreferrer"
                class="store-btn"
            >
                <img
                    src="/images/appstore.svg"
                    alt="App Store"
                    width="20"
                    height="20"
                />
                App Store
            </a>
        </div>

        <div class="social-proof-wrapper">
            <p id="tulaaSocialProof" class="social-proof-text">
                <em>Join 5,000+ users healing naturally</em>
            </p>
        </div>
    </div>
</section>

<script>
    // Minimalist Social Proof Cycling[cite: 2]
    const proofElement = document.getElementById("tulaaSocialProof");

    if (proofElement) {
        const socialProofs = [
            "Join 5,000+ users healing naturally",
            "Rated 5 stars on Play Store & App Store",
            "Yoga plans for 30+ health needs",
            "100% Private: No account needed",
            "Completely Free: No hidden costs",
        ];

        let currentIndex = 0;

        setInterval(() => {
            proofElement.style.opacity = "0";
            proofElement.style.transform = "translateY(5px)";

            setTimeout(() => {
                currentIndex = (currentIndex + 1) % socialProofs.length;
                proofElement.innerHTML = `<em>${socialProofs[currentIndex]}</em>`;
                proofElement.style.opacity = "1";
                proofElement.style.transform = "translateY(0)";
            }, 500);
        }, 4000);
    }
</script>
