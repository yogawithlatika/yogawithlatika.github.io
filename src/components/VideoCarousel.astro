---
// src/components/VideoCarousel.astro

const videoData = [
    {
        id: "ZcwZFpBXma0",
        title: "Yoga to reduce stress, improve sleep",
    },
    {
        id: "LAYgeIKm8m0",
        title: "Yoga for Back, Neck & Shoulder Pain Relief",
    },
    {
        id: "nwK-a0FJbEU",
        title: "Prenatal Guided Meditation",
    },
    {
        id: "ZuuvIa85QGI",
        title: "Yoga for Knee Stiffness & Pain",
    },
    {
        id: "dB66ygiGTbA",
        title: "10 minute Guided Chanting Meditation",
    },
];
---

<section id="showcase" class="section">
    <h2 class="text-center">Experience My Teaching Style</h2>
    <p class="text-center mb-1">
        Simple, effective, and scientifically backed yoga practices.
    </p>

    <div class="carousel" id="video-carousel">
        {
            videoData.map((video) => (
                <div class="video-card">
                    <a
                        href={`https://www.youtube.com/watch?v=${video.id}`}
                        target="_blank"
                    >
                        <img
                            src={`https://i.ytimg.com/vi/${video.id}/mqdefault.jpg`}
                            alt={video.title}
                            loading="lazy"
                        />
                        <p>{video.title}</p>
                    </a>
                </div>
            ))
        }
    </div>

    <div class="text-center mt-1">
        <a
            href="https://www.youtube.com/@yogawithlatika"
            target="_blank"
            rel="noopener noreferrer"
            class="button-accent"
        >
            📺 Visit YouTube Channel →
        </a>
    </div>
</section>
