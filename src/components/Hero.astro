---
// src/components/Hero.astro
---

<section id="home" class="section hero-section">
    <div class="hero-content">
        <div class="profile-avatar-container">
            <img
                src="/images/latika.png"
                alt="Latika Bissa"
                class="profile-avatar"
                width="200"
                height="200"
            />
        </div>

        <h1>Science-Backed <span class="text-gradient">Yoga Therapy</span></h1>
        <h2 class="profile-name">Latika Bissa</h2>

        <div class="credentials">
            <span>M.Sc Yoga Therapy</span>
            <span class="dot">•</span>
            <span>Gold Medalist</span>
            <span class="dot">•</span>
            <span>10+ Years Experience</span>
        </div>

        <p class="profile-bio">
            Welcome to a space designed for your restoration. I provide custom,
            evidence-based yoga solutions engineered to help you live a <strong
                class="text-gradient">pain-free, balanced life</strong
            >.
        </p>

        <div class="hero-actions">
            <a href="#tulaa" class="cta-button"> Download Tulaa App </a>
            <a href="#showcase" class="button-accent">
                Watch Practices on YouTube
            </a>
        </div>
    </div>
</section>
