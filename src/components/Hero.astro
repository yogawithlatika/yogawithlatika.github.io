---
// src/components/Hero.astro
---

<section id="home" class="section hero-section">
    <div class="hero-content">
        <div class="profile-avatar-container">
            <img
                src="/images/latika.png"
                alt="Latika Bissa"
                class="profile-avatar"
                width="140"
                height="140"
            />
        </div>

        <div class="profile-identity">
            <h1>
                Science-Backed <span class="text-gradient">Yoga Therapy</span> by
            </h1>
            <h2 class="profile-name">Latika Bissa</h2>

            <div class="credentials">
                <span>12+ Yrs Exp</span>
                <span class="dot">•</span>
                <span>5★ on Google</span>
                <span class="dot">•</span>
                <span>M.Sc Yoga</span>
            </div>
        </div>

        <p class="profile-bio">
            Transform your health with personalized yoga plans designed for a <strong
                class="text-gradient">pain-free, balanced life</strong
            >.
        </p>

        <div class="hero-actions">
            <a href="#tulaa" class="cta-button"> Download Tulaa App </a>
            <a href="#showcase" class="button-accent"> Watch on YouTube </a>
        </div>
    </div>
</section>
