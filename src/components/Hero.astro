---
// src/components/Hero.astro
---

<section id="home" class="section hero-section">
    <div class="hero-content">
        <div class="profile-avatar-container">
            <img
                src="/images/latika.png"
                alt="Latika Bissa - Certified Yoga Therapist"
                class="profile-avatar"
                width="140"
                height="140"
                loading="eager"
                decoding="async"
            />
        </div>

        <header class="profile-identity">
            <h1>
                <span class="title-sub"
                    >Science-Backed <span class="text-gradient"
                        >Yoga Therapy</span
                    > by</span
                >
                <span class="profile-name">Latika Bissa</span>
            </h1>

            <div
                class="credentials"
                aria-label="Professional credentials and ratings"
            >
                <span>12 Yrs Exp</span>
                <span class="dot" aria-hidden="true">•</span>
                <span aria-label="5 stars on Google">5★ on Google</span>
                <span class="dot" aria-hidden="true">•</span>
                <span>M.Sc Yoga</span>
            </div>
        </header>

        <p class="profile-bio">
            Transform your health with personalized yoga plans designed for a <strong
                class="text-gradient">pain-free, balanced life</strong
            >.
        </p>

        <div class="hero-actions">
            <a
                href="https://tulaa.app"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-button"
            >
                Download Tulaa App
            </a>
            <a
                href="https://www.youtube.com/@yogawithlatika"
                target="_blank"
                rel="noopener noreferrer"
                class="button-accent"
            >
                Watch on YouTube
            </a>
        </div>
    </div>
</section>
