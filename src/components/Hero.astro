---
// src/components/Hero.astro
---

<section id="about" class="section hero-section">
    <div class="hero-content">
        <div class="profile-avatar-container">
            <img
                src="/images/latika.png"
                alt="Latika Bissa"
                class="profile-avatar"
                width="200"
                height="200"
            />
        </div>

        <h1>Personalized Yoga Therapy</h1>
        <h2 class="profile-name">Latika Bissa</h2>

        <div class="credentials">
            <span>M.Sc Yoga Therapy</span>
            <span class="dot">•</span>
            <span>Gold Medalist</span>
            <span class="dot">•</span>
            <span>10+ Years Experience</span>
        </div>

        <p class="profile-bio">
            Bridging ancient yogic wisdom with modern medical science.
            Specializing in 1-on-1 therapeutic care for <strong
                >Chronic Pain, Thyroid, PCOS, and Prenatal Wellness.</strong
            >
        </p>

        <div class="hero-actions">
            <a
                href="https://api.whatsapp.com/send?phone=919663201627&text=Hi%20Latika%2C%20I%20am%20interested%20in%20starting%20my%20Yoga%20journey%20with%20you%20🙏"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-button"
            >
                Book a Consultation
            </a>
            <a href="#tulaa" class="button-accent"> Explore Free App </a>
        </div>
    </div>
</section>
