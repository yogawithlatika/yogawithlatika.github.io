---
// src/components/Hero.astro
---

<section id="about" class="section hero-section">
    <div class="text-center">
        <h1>Personalized Yoga Therapy & Wellness</h1>

        <div class="profile-avatar-container">
            <img
                src="/images/latika_profile_pic.webp"
                alt="Latika Bissa Yoga Therapist"
                class="profile-avatar"
                width="250"
                height="250"
            />
        </div>

        <h2 class="profile-name">Latika Bissa</h2>

        <div class="founder-portfolio">
            <div class="portfolio-title">Founder & Creator</div>

            <div class="portfolio-list">
                <div class="portfolio-item">
                    <img
                        src="/images/yogawithlatika_logo_128.webp"
                        alt="YogaWithLatika Logo"
                        class="portfolio-icon"
                    />
                    <div class="portfolio-text">
                        <strong>YogaWithLatika</strong>
                        <span>Online Yoga Studio & 1-on-1 Therapy</span>
                    </div>
                </div>

                <a
                    href="https://tulaalife.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="portfolio-item"
                >
                    <img
                        src="/images/tulaa_logo_128.webp"
                        alt="Tulaa App Logo"
                        class="portfolio-icon"
                    />
                    <div class="portfolio-text">
                        <strong>Tulaa App</strong>
                        <span>Free, Privacy-First Wellness App</span>
                    </div>
                </a>

                <a
                    href="https://www.youtube.com/@yogawithlatika"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="portfolio-item"
                >
                    <div class="portfolio-icon icon-wrapper yt-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"
                            ></path>
                        </svg>
                    </div>
                    <div class="portfolio-text">
                        <strong>YouTube Community</strong>
                        <span>5,000+ Subscribers • 20,000+ Watch Hours</span>
                    </div>
                </a>

                <div class="portfolio-item">
                    <div class="portfolio-icon icon-wrapper edu-icon-wrapper">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
                            ></path>
                        </svg>
                    </div>
                    <div class="portfolio-text">
                        <strong>M.Sc & B.Sc Yoga Therapy</strong>
                        <span>Gold Medalist • 10+ Years Experience</span>
                    </div>
                </div>
            </div>
        </div>

        <p class="profile-bio">
            I bridge the gap between <strong
                >ancient yogic wisdom and modern medical science</strong
            >. With over <strong>10 years</strong> of experience, I specialize in
            1-on-1 therapeutic care for
            <strong>
                Chronic Body Pain, Thyroid Health, PCOS, Prenatal Wellness, and
                comprehensive holistic healing</strong
            >. Join the <strong>5,000+ clients</strong> I've helped heal and thrive.
        </p>

        <div class="button-container">
            <a
                href="https://api.whatsapp.com/send?phone=919663201627&text=Hi%20Latika%2C%20I%20am%20interested%20in%20starting%20my%20Yoga%20journey%20with%20you%20🙏"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-button"
            >
                Book a Consultation
            </a>
            <a
                href="https://tulaalife.com"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-button secondary"
                id="getAppBtn"
            >
                Get Free Yoga App
            </a>
        </div>
    </div>
</section>

<script>
    // App CTA Visibility Logic (URL Parameter Check)
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("hide_app_cta") === "true") {
        const appBtn = document.getElementById("getAppBtn");
        if (appBtn) {
            appBtn.style.display = "none";
        }
    }
</script>
