---
// src/components/About.astro
---

<section id="about" class="section hero-section">
    <div class="hero-content">
        <h2>Science & Ancient Wisdom</h2>

        <p class="profile-bio">
            With over <strong>12 years</strong> of experience, I provide highly specialized,
            1-on-1 therapeutic yoga plans for <span class="text-gradient"
                >Chronic Pain Relief</span
            >
            (Back, Neck & Shoulder), targeted therapy for <span
                class="text-gradient">PCOS & Thyroid</span
            >, and gentle care for Prenatal Wellness and Anxiety.
        </p>

        <div
            class="credentials"
            style="margin-bottom: clamp(1.5rem, 4vw, 2.5rem);"
        >
            <span>Guided in English, Hindi & Marathi</span>
        </div>

        <div class="hero-actions">
            <a
                href="https://api.whatsapp.com/send?phone=919663201627&text=Hi%20Latika%2C%20I%20am%20interested%20in%20starting%20my%20Yoga%20journey%20with%20you%20🙏"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-button"
            >
                Book Consultation
            </a>
            <a href="#tulaa" class="button-accent"> Explore App </a>
        </div>
    </div>
</section>
