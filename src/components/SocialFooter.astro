<!-- Floating WhatsApp Action -->
<a
    href="https://api.whatsapp.com/send?phone=919663201627&text=Hi%20Latika%2C%20I%20am%20interested%20in%20starting%20my%20Yoga%20journey%20with%20you%20🙏"
    target="_blank"
    rel="noopener noreferrer"
    class="chat-float"
    id="whatsappFloat"
    aria-label="Chat with Latika on WhatsApp"
>
    <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
    >
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path>
    </svg>
    <span class="chat-text">Chat with Latika</span>
</a>
